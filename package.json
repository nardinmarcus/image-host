{
  "name": "image-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "d1": "wrangler d1 execute img --local --file=./tgimglog.sql",
    "d1:migrations:list": "wrangler d1 migrations list IMG --remote",
    "d1:migrations:apply": "wrangler d1 migrations apply IMG --remote",
    "d1:migrations:list:local": "wrangler d1 migrations list IMG --local --config wrangler.local.jsonc",
    "d1:migrations:apply:local": "wrangler d1 migrations apply IMG --local --config wrangler.local.jsonc",
    "verify:p0-p1": "node scripts/verify-p0-p1.mjs"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.12.1",
    "@fortawesome/fontawesome-svg-core": "^6.5.2",
    "@fortawesome/free-brands-svg-icons": "^6.5.2",
    "@fortawesome/free-regular-svg-icons": "^6.5.2",
    "@fortawesome/free-solid-svg-icons": "^6.5.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@next/third-parties": "^14.2.5",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "react": "^18",
    "react-dom": "^18",
    "react-photo-view": "^1.2.6",
    "react-toastify": "^10.0.5"
  },
  "devDependencies": {
    "@types/react": "18.3.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "wrangler": "^3.114.17"
  }
}
